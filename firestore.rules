rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Users collection - users can read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Admins collection - only readable by admins themselves
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // Admins are created manually in Firebase Console
    }
    
    // Centers collection - anyone authenticated can read, owners and admins can write
    match /centers/{centerId} {
      // Allow read for all authenticated users (for listing and queries)
      allow read: if request.auth != null;
      
      // Allow create for authenticated users
      allow create: if request.auth != null;
      
      // Allow update by the owner OR by an admin (for approval/rejection)
      allow update: if request.auth != null && 
                       (resource.data.userId == request.auth.uid || isAdmin());
      
      // Allow delete only by the owner or admin
      allow delete: if request.auth != null && 
                       (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Appointments collection - users can create and manage their own appointments
    match /appointments/{appointmentId} {
      // Allow read for appointment owner OR center owner (to see appointments at their center)
      allow read: if request.auth != null;
      
      // Users can create appointments
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'centerId', 
                         'centerName', 'appointmentDate', 'appointmentTime', 
                         'purpose', 'status']);
      
      // Users can update their own appointments OR center owners can update (approve/reject)
      allow update: if request.auth != null;
      
      // Users can delete their own appointments
      allow delete: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
    }
    
    // Notifications collection - center owners and users can read and manage their notifications
    match /notifications/{notificationId} {
      // Allow list queries for authenticated users (filtered by centerOwnerId or userId in app)
      allow read: if request.auth != null;
      
      // Anyone authenticated can create notifications (for appointment bookings and status updates)
      allow create: if request.auth != null;
      
      // Center owners can update/delete their notifications (centerOwnerId)
      // Users can update/delete their notifications (userId)
      allow update, delete: if request.auth != null && 
                               (resource.data.centerOwnerId == request.auth.uid || 
                                resource.data.userId == request.auth.uid);
    }
    
    // Counters collection - used for sequential appointment numbering
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Documents collection - all authenticated users can read, creators can manage their own
    match /documents/{documentId} {
      // All authenticated users can read documents (visible to everyone)
      allow read: if request.auth != null;
      
      // Authenticated users can create documents
      allow create: if request.auth != null && 
                       request.resource.data.createdBy == request.auth.uid;
      
      // Only the creator can update their own documents
      allow update: if request.auth != null && 
                       resource.data.createdBy == request.auth.uid;
      
      // Only the creator can delete their own documents
      allow delete: if request.auth != null && 
                       resource.data.createdBy == request.auth.uid;
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
