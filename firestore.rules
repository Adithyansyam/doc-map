rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - users can read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Centers collection - anyone authenticated can read, only center owners can write
    match /centers/{centerId} {
      // Allow read for all authenticated users (for listing and queries)
      allow read: if request.auth != null;
      
      // Allow create for authenticated users
      allow create: if request.auth != null;
      
      // Allow update/delete only by the owner
      allow update, delete: if request.auth != null && 
                             resource.data.userId == request.auth.uid;
    }
    
    // Appointments collection - users can create and manage their own appointments
    match /appointments/{appointmentId} {
      // Anyone authenticated can read their own appointments
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid || 
                      resource.data.centerId == request.auth.uid);
      
      // Users can create appointments
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'centerId', 
                         'centerName', 'appointmentDate', 'appointmentTime', 
                         'purpose', 'status']);
      
      // Users can update/delete their own appointments
      allow update: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
      
      allow delete: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
    }
    
    // Notifications collection - center owners can read and manage their notifications
    match /notifications/{notificationId} {
      // Allow list queries for authenticated users (filtered by centerOwnerId in app)
      // Note: Firestore rules can't filter list queries, so we allow read for authenticated users
      // The app filters by centerOwnerId in the query
      allow read: if request.auth != null;
      
      // Anyone authenticated can create notifications (for appointment bookings)
      allow create: if request.auth != null;
      
      // Center owners can update/delete their own notifications
      allow update, delete: if request.auth != null && 
                               resource.data.centerOwnerId == request.auth.uid;
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
